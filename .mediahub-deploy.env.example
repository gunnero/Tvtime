# Copy to .mediahub-deploy.env and keep the real values private.
MEDIAHUB_SSH_TARGET=deploy@example-host
MEDIAHUB_SSH_IDENTITY=/absolute/path/to/private-key
MEDIAHUB_SERVER_USER=mediahub
MEDIAHUB_SERVER_APP_DIR=/srv/mediahub/app
MEDIAHUB_SERVER_BACKUP_ROOT=/srv/mediahub/backups
MEDIAHUB_APACHE_CONF=/etc/apache2/sites-available/mediahub.example.conf
MEDIAHUB_LIVE_URL=https://mediahub.example.com

# Usually unchanged.
MEDIAHUB_BRANCH=main
MEDIAHUB_REMOTE=origin
